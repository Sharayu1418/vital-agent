# Copy to .env for local dev. NEVER commit .env.
# GCP — local dev uses `gcloud auth application-default login`; Cloud Run uses its service identity (no key file, ever)
GOOGLE_CLOUD_PROJECT=vital-agent-dev
GOOGLE_CLOUD_LOCATION=us-east1

# Model tiering (D5): Flash by default
VITAL_MODEL=gemini-2.5-flash

# Tool provider keys (D6: these stay inside adapters)
OPENWEATHER_API_KEY=your-key-here
GOOGLE_PLACES_API_KEY=your-key-here
