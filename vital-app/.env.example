# Copy to .env for local dev. NEVER commit .env.
# GCP — local dev uses `gcloud auth application-default login`; Cloud Run uses its service identity (no key file, ever)
GOOGLE_CLOUD_PROJECT=vital-agent-dev
GOOGLE_CLOUD_LOCATION=us-east1

# Model tiering (D5): Flash by default
VITAL_MODEL=gemini-2.5-flash

# Tool provider keys (D6: these stay inside adapters)
OPENWEATHER_API_KEY=your-key-here
GOOGLE_PLACES_API_KEY=your-key-here

# Security — dev settings. In prod: DEBUG_ENDPOINTS stays false,
# API_AUTH_TOKEN comes from Secret Manager (generate: openssl rand -hex 32).
# NOTE: DEBUG_ENDPOINTS=true refuses to boot without a non-empty token.
DEBUG_ENDPOINTS=true
API_AUTH_TOKEN=dev-only-token-change-me
# Local dev runs over http, so opt OUT of the Secure cookie flag here.
# In prod this stays unset -> defaults to true (HTTPS-only cookies).
SESSION_COOKIE_SECURE=false
# Cookie scope. 'lax' (default) for same-site setups: localhost dev, or
# app.yourdomain.com + api.yourdomain.com in prod (recommended).
# Vercel <-> Cloud Run on separate sites: set 'none' (requires
# SESSION_COOKIE_SECURE=true; enables the origin-check CSRF guard).
# SESSION_COOKIE_SAMESITE=lax

# Phase 2: sandboxed analysis (key from e2b.dev — free tier is fine for dev)
E2B_API_KEY=your-key-here

# Phase 3: events (free key: developer.ticketmaster.com). Optional —
# the events tool reports 'not configured' gracefully without it.
# TICKETMASTER_API_KEY=

# Phase 4: observability — LangSmith traces every agent hop (smith.langchain.com)
# LANGSMITH_TRACING=true
# LANGSMITH_API_KEY=
# LANGSMITH_PROJECT=vital-dev

# Phase 4: guardrails (defaults shown; per-user daily cap)
# DAILY_TOKEN_BUDGET=50000
# RECURSION_LIMIT=25


# --- Firebase Authentication (Google Sign-In) ---
# OFF locally by default; tests never need it. In prod (Cloud Run) set:
#   FIREBASE_AUTH_ENABLED=true
#   FIREBASE_PROJECT_ID=vital-agent-dev
# Verification uses Application Default Credentials (the Cloud Run service
# identity). There is NO service-account JSON key, ever.
FIREBASE_AUTH_ENABLED=false
FIREBASE_PROJECT_ID=vital-agent-dev
