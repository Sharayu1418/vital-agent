# Copy to .env.local for local dev. NEVER commit .env.local.

# Backend origin (FastAPI). Local dev:
NEXT_PUBLIC_API_BASE=http://localhost:8000

# --- Firebase web config (Google Sign-In) ---
# These are PUBLIC configuration values (they ship in the JS bundle by
# design; access control happens on the backend via ID-token verification).
# Get them from Firebase Console → Project settings → Your apps → Web app.
# Leave them empty to run without sign-in (anonymous mode only).
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=vital-agent-dev
NEXT_PUBLIC_FIREBASE_APP_ID=
